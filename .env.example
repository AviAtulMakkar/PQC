# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=pqcscanner
POSTGRES_USER=pqcuser
POSTGRES_PASSWORD=change-me-db-password

# ── FastAPI / JWT ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-32chars

# ── SMTP (optional — leave blank to disable email) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@pqcscanner.com
FROM_NAME=PQC Scanner

# ── Subdomain Discovery APIs (optional — discovery still works without them) ──
SHODAN_API_KEY=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
